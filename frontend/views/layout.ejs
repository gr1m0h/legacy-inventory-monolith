<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <!-- VULN: Loading jQuery 1.8.3 from CDN - old version with known XSS vulnerabilities -->
    <script src="https://code.jquery.com/jquery-1.8.3.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <h1>在庫管理システム</h1>
        <div class="nav">
            <a href="#" onclick="showSection('inventory')">在庫一覧</a>
            <a href="#" onclick="showSection('warehouses')">倉庫一覧</a>
            <a href="#" onclick="showSection('reports')">レポート</a>
            <a href="#" onclick="showSection('login')">ログイン</a>
        </div>
        <div id="user-info" style="display:none;">
            <span id="username-display"></span>
            <a href="#" onclick="logout()">ログアウト</a>
        </div>
    </div>

    <div class="container">
        <!-- Login Section -->
        <div id="login-section" class="section" style="display:none;">
            <h2>ログイン</h2>
            <form id="login-form" onsubmit="return handleLogin(event)">
                <div class="form-group">
                    <label>ユーザー名:</label>
                    <input type="text" id="login-username" name="username">
                </div>
                <div class="form-group">
                    <label>パスワード:</label>
                    <input type="password" id="login-password" name="password">
                </div>
                <button type="submit">ログイン</button>
                <div id="login-error" class="error"></div>
            </form>
        </div>

        <!-- Inventory Section -->
        <div id="inventory-section" class="section">
            <h2>在庫一覧</h2>
            <div class="search-bar">
                <input type="text" id="search-input" placeholder="商品名で検索...">
                <select id="category-filter">
                    <option value="">全カテゴリ</option>
                    <option value="Electronics">Electronics</option>
                    <option value="Mechanical">Mechanical</option>
                    <option value="Chemical">Chemical</option>
                    <option value="Packaging">Packaging</option>
                    <option value="Tools">Tools</option>
                </select>
                <button onclick="searchInventory()">検索</button>
            </div>
            <div id="inventory-table"></div>
            <div id="inventory-pagination"></div>
        </div>

        <!-- Warehouses Section -->
        <div id="warehouses-section" class="section" style="display:none;">
            <h2>倉庫一覧</h2>
            <div id="warehouses-table"></div>
        </div>

        <!-- Warehouse Detail -->
        <div id="warehouse-detail-section" class="section" style="display:none;">
            <h2 id="warehouse-detail-title"></h2>
            <div id="warehouse-detail-content"></div>
        </div>

        <!-- Reports Section -->
        <div id="reports-section" class="section" style="display:none;">
            <h2>レポート</h2>
            <div id="reports-content"></div>
        </div>

        <!-- Status Bar -->
        <div id="status-bar">
            <span id="status-message">準備完了</span>
        </div>
    </div>

    <script src="/js/api.js"></script>
    <script src="/js/app.js"></script>
    <script>
        // VULN: Exposing backend URL in client-side JavaScript
        var API_BASE = '';  // Proxy through frontend
        $(document).ready(function() {
            loadInventory();
        });
    </script>
</body>
</html>
